# 複製成 .env.local 後填入實際的值（.env.local 已被 gitignore，不會進版控）
# 這些值可以在 Supabase 專案的 Settings → API 找到。

# 專案 URL，例如 https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# anon public key —— 會被送到瀏覽器端，靠 Row Level Security 保護資料
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key —— 會繞過所有 RLS 政策。
# 只能在伺服器端使用，絕對不要加 NEXT_PUBLIC_ 前綴，否則會被打包進前端。
SUPABASE_SERVICE_ROLE_KEY=
